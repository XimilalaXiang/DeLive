{
  "name": "delive",
  "version": "1.7.0",
  "description": "DeLive",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "author": "XimilalaXiang",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:client": "cd frontend && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && cross-env NODE_ENV=development electron .",
    "build": "npm run generate-icons && npm run build:client && npm run build:electron",
    "build:client": "cd frontend && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "lint:frontend": "cd frontend && npm run lint",
    "test:frontend": "cd frontend && npm run test",
    "check": "npm run lint:frontend && npm run test:frontend && npm run build",
    "fetch:whisper-runtime": "node scripts/fetch-whisper-runtime.mjs",
    "stage:whisper-runtime": "node scripts/stage-whisper-runtime.mjs",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux",
    "install:all": "npm install && cd frontend && npm install && cd ../server && npm install",
    "generate-icons": "node scripts/generate-icons.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/pako": "^2.0.4",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.delive.app",
    "productName": "DeLive",
    "copyright": "Copyright © 2024 XimilalaXiang",
    "icon": "build/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*",
      "frontend/public/**/*",
      "local-runtimes/**/*",
      "build/icon.ico",
      "build/icon.png"
    ],
    "asarUnpack": [
      "local-runtimes/**/*",
      "build/icon.ico",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "local-runtimes",
        "to": "local-runtimes"
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "build/icon.ico",
          "to": "build/icon.ico"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "build/icon.icns",
      "extraResources": [
        {
          "from": "build/icon.icns",
          "to": "build/icon.icns"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "DeLive needs microphone access for real-time audio transcription",
        "NSAudioCaptureUsageDescription": "DeLive needs to capture system audio for real-time transcription"
      }
    },
    "linux": {
      "maintainer": "XimilalaXiang",
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "DeLive"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "XimilalaXiang",
      "repo": "DeLive",
      "releaseType": "release"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cors": "^2.8.5",
    "electron-updater": "^6.7.3",
    "express": "^4.21.2",
    "pako": "^2.1.0",
    "ws": "^8.19.0"
  }
}
